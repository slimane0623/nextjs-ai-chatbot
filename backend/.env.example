# Local chat provider: ollama or llama_cpp
CHAT_PROVIDER=ollama

# Model name exposed by your local provider
CHAT_MODEL=llama3.2:1b

# Global timeout for local model calls (milliseconds)
CHAT_TIMEOUT_MS=45000

# Stability controls for local load tests
CHAT_MAX_CONCURRENT=1
CHAT_STATUS_CACHE_TTL_MS=5000

# Keep model warm and cap generation length to reduce timeout risk
CHAT_MAX_TOKENS=600
OLLAMA_KEEP_ALIVE=30m

# Provider base URLs
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLAMA_CPP_BASE_URL=http://127.0.0.1:8080

# Safety disclaimer always appended in chat responses
CHAT_DISCLAIMER=Assistant local informatif uniquement. Ne remplace pas un avis medical professionnel.
